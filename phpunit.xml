<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true"
         stopOnFailure="false"
>
    <testsuites>
        <testsuite name="Unit">
            <directory>tests/Unit</directory>
        </testsuite>
        <testsuite name="Feature">
            <directory>tests/Feature</directory>
        </testsuite>
        <testsuite name="Iteración 1 – Gestión de Usuarios y Autenticación">
            <file>tests/Feature/UserManagementTest.php</file>
            <file>tests/Feature/RoleAccessControlTest.php</file>
            <file>tests/Feature/AuthenticationTest.php</file>
        </testsuite>
        <testsuite name="Iteración 2 – Gestión Académica Básica">
            <file>tests/Feature/CourseManagementTest.php</file>
        </testsuite>
        <testsuite name="Iteración 3 – Gestión de Estudiantes en Cursos">
            <file>tests/Feature/StudentEnrollmentTest.php</file>
        </testsuite>
        <testsuite name="Iteración 4 – Gestión de OVAs y Contenido Educativo">
            <file>tests/Feature/OvaManagementTest.php</file>
        </testsuite>
        <testsuite name="Iteración 5 – Asignación y Uso Didáctico de OVAs en Cursos">
            <file>tests/Feature/CourseOvaAssignmentTest.php</file>
        </testsuite>
        <testsuite name="Iteración 6 – Evaluación y Seguimiento Académico">
            <file>tests/Feature/StudentAcademicExperienceTest.php</file>
        </testsuite>
        <testsuite name="Iteración 7 – Reportes y Analítica">
            <file>tests/Feature/ReportsAndAnalyticsTest.php</file>
        </testsuite>
    </testsuites>

    <source>
        <include>
            <directory>app</directory>
        </include>
    </source>

    <php>
        <env name="APP_ENV"          value="testing"/>
        <env name="BCRYPT_ROUNDS"    value="4"/>
        <env name="CACHE_STORE"      value="array"/>
        <env name="DB_CONNECTION"    value="sqlite"/>
        <env name="DB_DATABASE"      value=":memory:"/>
        <env name="MAIL_MAILER"      value="array"/>
        <env name="QUEUE_CONNECTION" value="sync"/>
        <env name="SESSION_DRIVER"   value="array"/>
    </php>
</phpunit>